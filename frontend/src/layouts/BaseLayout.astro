---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Prediction Radar',
  description = 'Discover where the world is changing its mind.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="container header-inner">
        <a href="/" class="brand">
          <span class="brand-mark">PR</span>
          <span>Prediction Radar</span>
        </a>
        <p class="header-note">Signal discovery, not betting advice.</p>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="container">
        <p>Data source: Polymarket public API. Updated every 15 minutes.</p>
      </div>
    </footer>
  </body>
</html>
